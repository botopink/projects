// yamlconf — using the config template (expr-templates showcase).

import {conf} from "yamlconf";

val cfg = conf
    \\server:
    \\  host: "0.0.0.0"
    \\debug: true
;

fn main() {
    @print(cfg.server.port + 1);   // ok: i32 — structure revealed at expansion
    @print(cfg.debug);             // ok: bool
    // @print(cfg.server.prot);    // COMPILE ERROR: 'record' has no field 'prot'
}
