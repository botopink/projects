// Records + enum + case + lambda. The full set runs on commonJS + erlang (the
// `test` block asserts records, a captured lambda, and 3-variant case dispatch).
//
// `main()` is deliberately a SINGLE enum→`case` call so it is also BEAM-safe:
// it returns 3 on commonJS/erlang/beam, pinning that `case…of` enum dispatch
// codegens and runs on BEAM. Two BEAM reds are intentionally kept out of
// `main()` and recorded (front-c-runtime.md C2): a lambda lowers to a `#Fun`
// that BEAM then mis-applies to `*` (`badarith`), and `call + call` integer
// arithmetic trips `beam_validator` — both Front-A codegen gaps. (wasm carries
// no records/enums; its numeric core is the `numeric` fixture.)

enum Shape { Circle, Square, Triangle }

record Box { w: i32, h: i32 }

fn sides(s: Shape) -> i32 {
  return case s {
    Circle -> 0,
    Square -> 4,
    Triangle -> 3,
  };
}

fn area(b: Box) -> i32 {
  val twice = { x -> x * 1 };
  return twice(b.w * b.h);
}

pub fn main() -> i32 {
  return sides(Shape.Triangle);
}

test "records, enum, case and lambda agree across backends" {
  assert sides(Shape.Circle) == 0;
  assert sides(Shape.Square) == 4;
  assert sides(Shape.Triangle) == 3;
  assert area(Box(w: 2, h: 3)) == 6;
  assert main() == 3;
}
