//// The `rakun` package — module-tree root.
////
//// The Spring-style framework's compiled surface: `decorators` (the component
//// markers AS comptime decorator fns + the DI/router wiring they `@emit`),
//// `http` (the `HttpMethod` enum · `Response` · `App` value types), and
//// `runtime` (the `#[@external]` declarations binding the `runtime.mjs` mutable
//// seams). All three are public surface, reached by a consumer via `import {…}
//// from "rakun"` — the `@emit`ted wiring imports the runtime fns by name.
////
//// The boundary interfaces stay in a declaration module — `rakun.d.bp`
//// (`Request`/`Context`/`Rakun`) — wired through `botopink.json` `files` (loaded
//// with `.declaration = true` for a consumer), not the build tree: `.d.bp`
//// modules are not resolved by `mod` paths, mirroring how `libs/std` keeps its
//// ambient `.d.bp` out of `root.bp`.

pub mod decorators;
pub mod http;
pub mod runtime;
