//// Tests for the builtin `Array<T>` interface (array.d.bp), run by
//// `botopink test`. Covers the surface that lowers correctly on the
//// commonJS target today — see libs/std/test/AGENTS.md for gaps.

test "array join" {
    val xs = ["a", "b", "c"];
    assert xs.join("-") == "a-b-c";
}

test "array reverse" {
    val ns = [1, 2, 3];
    assert ns.reverse().join(",") == "3,2,1";
}

test "array indexOf and at" {
    val ns = [1, 2, 3];
    assert ns.indexOf(3) == 2;
    assert ns.at(1) == 2;
}

test "array map" {
    val ns = [1, 2, 3];
    val sq = ns.map({ x -> x * x });
    assert sq.join(",") == "1,4,9";
}

test "array filter" {
    val ns = [1, 2, 3, 4];
    val ev = ns.filter({ n -> n % 2 == 0 });
    assert ev.join(",") == "2,4";
}

test "array slice" {
    val ns = [1, 2, 3, 4];
    assert ns.slice(1, 3).join(",") == "2,3";
}
