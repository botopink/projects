//// Tests for the `order` std module (order.bp): constructor fns, `toInt`,
//// `reverse`, and a `case` over the exported `Order` enum (type export).

import {order} from "std";

test "order toInt" {
    assert order.toInt(order.lt()) == -1;
    assert order.toInt(order.eq()) == 0;
    assert order.toInt(order.gt()) == 1;
}

test "order reverse" {
    assert order.toInt(order.reverse(order.lt())) == 1;
    assert order.toInt(order.reverse(order.gt())) == -1;
    assert order.toInt(order.reverse(order.eq())) == 0;
}

test "case over imported Order" {
    val o = order.reverse(order.lt());
    val s = case o {
        Lt -> "less";
        Gt -> "greater";
        _ -> "equal";
    };
    assert s == "greater";
}
