//// Tests for the `dict` std module (dict.bp).
//// Qualified calls via `import {dict} from "std"`.
////
//// API note: `dict.empty()` (not `dict.new` — `new` is a keyword) and
//// `dict.lookup()` (not `dict.get` — `get` is a keyword).
////
//// Equality assertions on arrays use `.join(",")` (structural == is ref-eq on JS).

import {dict} from "std";

test "dict empty is empty" {
    val d = dict.empty();
    assert dict.isEmpty(d);
    assert dict.size(d) == 0;
}

test "dict insert and lookup" {
    val d = dict.insert(dict.empty(), "a", 1);
    assert dict.lookup(d, "a").unwrapOr(0) == 1;
    assert dict.lookup(d, "z").unwrapOr(-1) == -1;
}

test "dict pipeline: insert chain" {
    val d = dict.empty()
        |> dict.insert("x", 10)
        |> dict.insert("y", 20)
        |> dict.insert("z", 30);
    assert dict.lookup(d, "x").unwrapOr(0) == 10;
    assert dict.lookup(d, "y").unwrapOr(0) == 20;
    assert dict.lookup(d, "z").unwrapOr(0) == 30;
}

test "dict hasKey" {
    val d = dict.insert(dict.empty(), "k", 99);
    assert dict.hasKey(d, "k");
    assert !dict.hasKey(d, "missing");
}

test "dict delete removes key" {
    val d = dict.delete(
        dict.insert(dict.insert(dict.empty(), "a", 1), "b", 2),
        "a");
    assert !dict.hasKey(d, "a");
    assert dict.lookup(d, "b").unwrapOr(0) == 2;
}

test "dict insert overwrites duplicate" {
    val d = dict.insert(dict.insert(dict.empty(), "k", 1), "k", 99);
    assert dict.size(d) == 1;
    assert dict.lookup(d, "k").unwrapOr(0) == 99;
}

test "dict size counts unique keys" {
    val d = dict.insert(dict.insert(dict.empty(), "a", 1), "b", 2);
    assert dict.size(d) == 2;
}

test "dict keys" {
    val d = dict.insert(dict.insert(dict.empty(), "a", 1), "b", 2);
    val ks = dict.keys(d);
    assert ks.length == 2;
}

test "dict values" {
    val d = dict.insert(dict.insert(dict.empty(), "a", 10), "b", 20);
    val vs = dict.values(d);
    assert vs.length == 2;
}

test "dict fold sums values" {
    val d = dict.insert(dict.insert(dict.empty(), "a", 3), "b", 7);
    val total = dict.fold(d, 0, { acc, k, v -> acc + v });
    assert total == 10;
}

test "dict merge right-biased" {
    val a = dict.insert(dict.empty(), "k", 1);
    val b = dict.insert(dict.empty(), "k", 99);
    val m = dict.merge(a, b);
    assert dict.lookup(m, "k").unwrapOr(0) == 99;
}

test "dict mapValues transforms values" {
    val d = dict.insert(dict.insert(dict.empty(), "a", 3), "b", 7);
    val doubled = dict.mapValues(d, { v -> v * 2 });
    assert dict.lookup(doubled, "a").unwrapOr(0) == 6;
    assert dict.lookup(doubled, "b").unwrapOr(0) == 14;
}
