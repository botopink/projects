//// Tests for the `sets` std module (sets.bp).
//// Qualified calls via `import {sets} from "std"`.
////
//// NOTE: module is named `sets` (not `set`) because `set` is a keyword token.
//// The constructor is `sets.empty()` (not `sets.new` — `new` is a keyword).

import {sets} from "std";

test "sets empty is empty" {
    assert sets.isEmpty(sets.empty());
    assert sets.size(sets.empty()) == 0;
}

test "sets insert and contains" {
    val s = sets.insert(sets.insert(sets.empty(), "a"), "b");
    assert sets.contains(s, "a");
    assert sets.contains(s, "b");
    assert !sets.contains(s, "c");
}

test "sets insert is idempotent" {
    val s = sets.insert(sets.insert(sets.empty(), "x"), "x");
    assert sets.size(s) == 1;
}

test "sets delete removes element" {
    val s = sets.delete(sets.insert(sets.insert(sets.empty(), "a"), "b"), "a");
    assert !sets.contains(s, "a");
    assert sets.contains(s, "b");
}

test "sets fromList deduplicates" {
    val s = sets.fromList([1, 2, 2, 3, 1]);
    assert sets.size(s) == 3;
}

test "sets toList round-trips" {
    val s = sets.fromList(["x", "y", "z"]);
    assert sets.toList(s).length == 3;
}

test "sets union combines without duplicates" {
    val a = sets.fromList([1, 2, 3]);
    val b = sets.fromList([2, 3, 4]);
    val u = sets.union(a, b);
    assert sets.size(u) == 4;
    assert sets.contains(u, 1);
    assert sets.contains(u, 4);
}

test "sets intersection keeps shared elements" {
    val a = sets.fromList([1, 2, 3]);
    val b = sets.fromList([2, 3, 4]);
    val i = sets.intersection(a, b);
    assert sets.size(i) == 2;
    assert sets.contains(i, 2);
    assert sets.contains(i, 3);
    assert !sets.contains(i, 1);
}

test "sets difference removes b from a" {
    val a = sets.fromList([1, 2, 3]);
    val b = sets.fromList([2, 3, 4]);
    val d = sets.difference(a, b);
    assert sets.size(d) == 1;
    assert sets.contains(d, 1);
    assert !sets.contains(d, 2);
}
