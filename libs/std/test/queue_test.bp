//// Tests for the `queue` std module (queue.bp).
//// Qualified calls via `import {queue} from "std"`.

import {queue} from "std";

test "queue empty is empty" {
    val q = queue.empty();
    assert queue.isEmpty(q);
    assert queue.size(q) == 0;
}

test "queue enqueue increases size" {
    val q = queue.enqueue(queue.empty(), 1);
    assert queue.size(q) == 1;
    assert !queue.isEmpty(q);
}

test "queue peek at front" {
    val q = queue.enqueue(queue.enqueue(queue.empty(), 10), 20);
    assert queue.peek(q).unwrapOr(-1) == 10;
}

test "queue dequeue returns front and rest" {
    val q = queue.enqueue(queue.enqueue(queue.empty(), 1), 2);
    val result = queue.dequeue(q);
    val rest = result._0;
    val head = result._1;
    assert head.unwrapOr(-1) == 1;
    assert queue.size(rest) == 1;
    assert queue.peek(rest).unwrapOr(-1) == 2;
}

test "queue dequeue empty returns null head" {
    val result = queue.dequeue(queue.empty());
    val head = result._1;
    assert head == null;
}

test "queue fifo order preserved" {
    val q = queue.enqueue(queue.enqueue(queue.enqueue(queue.empty(), 1), 2), 3);
    val r1 = queue.dequeue(q);
    val r2 = queue.dequeue(r1._0);
    val r3 = queue.dequeue(r2._0);
    assert r1._1.unwrapOr(-1) == 1;
    assert r2._1.unwrapOr(-1) == 2;
    assert r3._1.unwrapOr(-1) == 3;
}

test "queue fromList and toList round-trip" {
    val q = queue.fromList([10, 20, 30]);
    assert queue.size(q) == 3;
    assert queue.toList(q).join(",") == "10,20,30";
}
