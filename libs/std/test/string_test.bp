//// Tests for the builtin `String` interface (string.d.bp), run by
//// `botopink test`. Only the surface that lowers correctly on the
//// commonJS target today is covered — snake_case methods that still
//// lack a JS name mapping (to_upper, contains, index_of, …) are
//// catalogued in libs/std/test/AGENTS.md and tested once typed-value
//// method dispatch lands.

test "string split and length" {
    val s = "a,b";
    val parts = s.split(",");
    assert parts.length == 2;
}

test "string trim" {
    val padded = "  hi  ";
    assert padded.trim() == "hi";
}

test "string slice" {
    val h = "hello";
    assert h.slice(1, 3) == "el";
    assert h.slice(0, 2) == "he";
}
