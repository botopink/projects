//// Tests for the `bool` std module (bool.bp), run by `botopink test`.
//// Qualified calls via `import {bool} from "std"` (stdlib-gleam F2a).

import {bool} from "std";

test "bool negate" {
    assert bool.negate(false);
    assert bool.negate(bool.negate(true));
}

test "bool nor" {
    assert bool.nor(false, false);
    assert bool.negate(bool.nor(true, false));
}

test "bool nand" {
    assert bool.nand(true, false);
    assert bool.negate(bool.nand(true, true));
}

test "bool exclusiveOr" {
    assert bool.exclusiveOr(true, false);
    assert bool.negate(bool.exclusiveOr(true, true));
}

test "bool exclusiveNor" {
    assert bool.exclusiveNor(true, true);
    assert bool.negate(bool.exclusiveNor(true, false));
}
