//// Tests for the optional surface: `?T` builtin methods (`map`, `flatMap`,
//// `unwrapOr`) and optional chaining `?.` (no `option` module/namespace —
//// the design keeps optionals as `?` syntax only).

record User { name: string }

test "option map and unwrapOr" {
    val x: ?i32 = 3;
    val y = x.map({ n -> n * 2 });
    assert y.unwrapOr(0) == 6;
}

test "option unwrapOr on null" {
    val z: ?i32 = null;
    assert z.unwrapOr(7) == 7;
}

test "option flatMap" {
    val x: ?i32 = 3;
    val y = x.flatMap({ n -> x });
    assert y.unwrapOr(0) == 3;
}

test "optional chaining member access" {
    val u: ?User = User(name: "ana");
    val n = u?.name;
    assert n.unwrapOr("none") == "ana";
}

test "optional chaining short-circuits null" {
    val v: ?User = null;
    val n = v?.name;
    assert n.unwrapOr("none") == "none";
}
