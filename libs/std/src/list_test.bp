//// Tests for the `list` std module (`import {list} from "std"`).
//// Run: cd libs/std && botopink test

import {list} from "std";

test "list fold and map" {
    val xs = [1, 2, 3, 4];
    val doubled = list.map(xs, { x -> x * 2 });
    assert list.fold(doubled, 0, { acc, x -> acc + x }) == 20, "fold of doubled";
}

test "list filter length count" {
    val xs = [1, 2, 3, 4];
    assert list.length(list.filter(xs, { x -> x > 2 })) == 2, "filter > 2";
    assert list.count(xs, { x -> x > 1 }) == 3, "count > 1";
}

test "list contains first isEmpty" {
    val xs = [1, 2, 3];
    assert list.contains(xs, 3), "contains 3";
    assert list.isEmpty(list.filter(xs, { x -> x > 9 })), "filtered empty";
}

test "list take drop reverse" {
    val xs = [1, 2, 3, 4];
    assert list.take(xs, 2).join(",") == "1,2", "take 2";
    assert list.drop(xs, 2).join(",") == "3,4", "drop 2";
    assert list.reverse(xs).join(",") == "4,3,2,1", "reverse";
}

test "list range append prepend flatten" {
    assert list.range(1, 5).join(",") == "1,2,3,4", "range half-open";
    assert list.append([1, 2], [3, 4]).join(",") == "1,2,3,4", "append";
    assert list.prepend([2, 3], 1).join(",") == "1,2,3", "prepend";
    assert list.flatten([[1, 2], [3]]).join(",") == "1,2,3", "flatten";
}

test "list all any" {
    val xs = [2, 4, 6];
    assert list.all(xs, { x -> x > 1 }), "all > 1";
    assert list.any(xs, { x -> x > 5 }), "any > 5";
}
