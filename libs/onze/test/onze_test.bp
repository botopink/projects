// onze — runtime tests (mock recording, stubbing, matchers, verification).
//
// Run by `botopink test` from `libs/onze/`. These exercise the onze RUNTIME end to
// end: a mock records its calls, `when(...)` stubs returns, argument matchers pick
// the right stub, and `verify(...)` checks call counts.
//
// The `MockUserRepo` below is written by hand, but it is *exactly* the shape the
// `#[mock]` decorator (`src/onze.bp`) emits for `interface UserRepo`: a record
// implementing the interface whose every method funnels through `onzeInvoke`. The
// `botopink test` pipeline does not yet splice `@emit` contributions (a core
// test-mode gap, see ../AGENTS.md), so the synthesis is shown under `build` in
// `../examples/` and the runtime is proven here against the explicit form.
//
// Arrays are compared with `.join(",")` because botopink lowers `==` on arrays to
// JS reference equality (a general codegen trait, not an onze concern).

import {when, verify, eq, anyInt, times, never, atLeastOnce, onzeInvoke, onzeKey, onzeNewMock};

interface UserRepo {
    fn find(self: Self, id: i32) -> string
    fn all(self: Self) -> Array<string>
}

// === begin synthesized-by-`#[mock]` shape ===
record MockUserRepo implement UserRepo {
    __id: string,
    fn find(self: Self, id: i32) -> string {
        return onzeInvoke(self.__id, "find", [onzeKey(id)], "");
    }
    fn all(self: Self) -> Array<string> {
        return onzeInvoke(self.__id, "all", [], []);
    }
}
fn mockUserRepo() -> UserRepo {
    return MockUserRepo(__id: onzeNewMock());
}
// === end synthesized shape ===

// A unit under test that depends only on the interface.
record UserService {
    repo: UserRepo,
    pub fn list(self: Self) -> Array<string> {
        return self.repo.all();
    }
    pub fn name(self: Self, id: i32) -> string {
        return self.repo.find(id);
    }
}

test "onze: an unstubbed method returns the type-default" {
    val repo = mockUserRepo();
    assert repo.all().join(",") == "";
    assert repo.find(1) == "";
}

test "onze: when(...).thenReturn stubs a return value" {
    val repo = mockUserRepo();
    val _s = when(repo.all()).thenReturn(["ana", "bob"]);
    val svc = UserService(repo: repo);
    assert svc.list().join(",") == "ana,bob";
}

test "onze: eq(v) stubs only the matching argument" {
    val repo = mockUserRepo();
    val _s = when(repo.find(eq(7))).thenReturn("ana");
    val svc = UserService(repo: repo);
    assert svc.name(7) == "ana";
    assert svc.name(8) == "";
}

test "onze: anyInt() matches any argument" {
    val repo = mockUserRepo();
    val _s = when(repo.find(anyInt())).thenReturn("x");
    val svc = UserService(repo: repo);
    assert svc.name(1) == "x";
    assert svc.name(42) == "x";
}

test "onze: the last matching stub wins" {
    val repo = mockUserRepo();
    val _a = when(repo.find(anyInt())).thenReturn("default");
    val _b = when(repo.find(eq(7))).thenReturn("seven");
    val svc = UserService(repo: repo);
    assert svc.name(7) == "seven";
    assert svc.name(1) == "default";
}

test "onze: verify atLeastOnce / times / never" {
    val repo = mockUserRepo();
    val _s = when(repo.find(eq(7))).thenReturn("ana");
    val svc = UserService(repo: repo);
    val _1 = svc.name(7);
    val _2 = svc.list();

    val _v1 = verify(repo, atLeastOnce()).all();
    val _v2 = verify(repo, times(1)).find(eq(7));
    val _v3 = verify(repo, never()).find(eq(99));
}

test "onze: thenThrow raises when the call is matched" {
    val repo = mockUserRepo();
    val _s = when(repo.find(eq(0))).thenThrow("not found");
    val svc = UserService(repo: repo);
    // A non-matching call still returns the default rather than raising.
    assert svc.name(5) == "";
}
