// jhonstart-app — the index route (Next-style `app/page.bp`).
//
// A client component: it links to a couple of dynamic post routes. `Link`
// renders an anchor that the router intercepts for client-side navigation.

import { div, ul, li, Link } from "jhonstart";

pub fn Page() -> Element {
    div {
        ul {
            [
                li { Link("/posts/1") { "first post" } },
                li { Link("/posts/2") { "second post" } },
            ]
        }
    }
}
