// Forward reference + true mutual recursion, exercised on every backend.
//
// `main` calls `isEven`, which is *declared after it* — a forward reference.
// `isEven` and `isOdd` then call each other (true mutual recursion). Each has a
// bare-`if` base case (`if (n == 0) { return … };`) followed by the recursive
// tail call, so a backend that mishandles an else-less `if` statement (ending
// the function in the false branch instead of falling through) returns the
// wrong result. See `tasks/v0.beta.9/specs/mutual-recursion.md`.

pub fn main() -> bool {
  return isEven(10);
}

fn isEven(n: i32) -> bool {
  if (n == 0) { return true; };
  return isOdd(n - 1);
}

fn isOdd(n: i32) -> bool {
  if (n == 0) { return false; };
  return isEven(n - 1);
}

test "mutual recursion resolves across declaration order" {
  assert isEven(10) == true;
  assert isOdd(10) == false;
  assert isEven(7) == false;
  assert isOdd(7) == true;
}
